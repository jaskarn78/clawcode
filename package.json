{
  "name": "clawcode",
  "version": "0.2.0",
  "type": "module",
  "description": "Multi-agent orchestration system built natively on Claude Code",
  "bin": {
    "clawcode": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup && npm run copy-assets",
    "copy-assets": "mkdir -p dist/dashboard/static && cp -r src/dashboard/static/. dist/dashboard/static/",
    "test": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@huggingface/transformers": "^4.0.1",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "discord.js": "^14.26.2",
    "handlebars": "^4.7.9",
    "mysql2": "^3.22.1",
    "nanoid": "^5.1.7",
    "pdf-parse": "^2.4.5",
    "pino": "^9",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
