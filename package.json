{
  "name": "clawcode",
  "version": "1.2.8",
  "type": "module",
  "description": "Multi-agent orchestration system built natively on Claude Code",
  "bin": {
    "clawcode": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup && npm run copy-assets && npm run build:spa",
    "build:spa": "cd src/dashboard/client && vite build",
    "dev:spa": "cd src/dashboard/client && vite dev",
    "copy-assets": "mkdir -p dist/dashboard/static && cp -r src/dashboard/static/. dist/dashboard/static/",
    "postinstall": "node scripts/install/postinstall-shim.cjs",
    "test": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "prebuilds/",
    "scripts/install/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.132",
    "@anthropic-ai/sdk": "^0.95.1",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@huggingface/transformers": "^4.0.1",
    "@mozilla/readability": "^0.6.0",
    "@playwright/browser-chromium": "^1.59.1",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "discord.js": "^14.26.2",
    "handlebars": "^4.7.9",
    "jsdom": "^29.0.2",
    "mysql2": "^3.22.1",
    "nanoid": "^5.1.7",
    "p-retry": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9",
    "playwright-core": "^1.59.1",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.3"
  }
}
